<div data-section-id="{{ section.id }}" data-section-type="grid-banner-type-4" class="grid-banner-type-4">   
  <div class="grid-uniform">  
     <div class="grid__item grid-banner-type-4-right-column">   
       <div class="img-hover-effect-1 img-hover-effect">     
      {% if section.settings.link_4 != blank %}<a class="banner_half_img" href="{{ section.settings.link_4 }}">{% endif%}
      {% if section.settings.image_4 != blank %}
      <img src="{{ section.settings.image_4 | img_url: 'master' }}" alt="{{ section.settings.title_4 }}" />
      {% else %}
      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif%}           
      {% if section.settings.link_4 != blank %}  </a>
      {% endif%}
      <div class="featured-content">       
        {% if section.settings.title_4 != blank %}
        <h6 style="color:{{ section.settings.title_4_color }}">{{ section.settings.title_4 }}</h6>
        {% endif %}
        {% if section.settings.text_4 != blank %}
        <h2 style="color:{{ section.settings.text_4_color }}">{{ section.settings.text_4}}</h2>    
        {% endif %}  
        {% if section.settings.button_4 != blank %}
        <a class="btn one" href="{{ section.settings.link_4 }}" style="color:{{ section.settings.button_4_txt_color }};border:none;background-color:{{ section.settings.button_4_bg_color }};">{{ section.settings.button_4}}</a>    
        {% endif %}         
      </div>      
       </div>       
    </div>  
    <div class="grid__item grid-banner-type-4-left-column">   
       <div class="img-hover-effect-2 img-hover-effect">       
      {% if section.settings.link_3 != blank %}<a class="banner_half_img" href="{{ section.settings.link_3 }}">{% endif%}
      {% if section.settings.image_3 != blank %}
      <img src="{{ section.settings.image_3 | img_url: 'master' }}" alt="{{ section.settings.title_3 }}" />
      {% else %}

      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif%}           
      {% if section.settings.link_3 != blank %}  </a>

      {% endif%}
      <div class="featured-content">        
        {% if section.settings.title_3 != blank %}
        <h6 style="color:{{ section.settings.title_3_color }}">{{ section.settings.title_3 }}</h6>
        {% endif %}
        {% if section.settings.text_3 != blank %}
        <h2 style="color:{{ section.settings.text_3_color }}">{{ section.settings.text_3}}</h2>    
        {% endif %}  
        {% if section.settings.button_3 != blank %}
        <a class="btn two" href="{{ section.settings.link_3 }}" style="color:{{ section.settings.button_3_txt_color }};border:none;background-color:{{ section.settings.button_3_bg_color }};">{{ section.settings.button_3}}</a>    
        {% endif %}         
      </div>      
       </div>
    </div>    
    <div class="grid__item grid-banner-type-4_top">
     <div class="grid__item wide--one-half post-large--one-half large--one-half medium-down--one-third small--grid__item img-hover-effect-3 img-hover-effect">
      {% if section.settings.link_1 != blank %}<a class="banner_half_img" href="{{ section.settings.link_1 }}">{% endif%}
      {% if section.settings.image_1 != blank %}
      <img src="{{ section.settings.image_1 | img_url: 'master' }}" alt="{{ section.settings.title_1 }}" />
      {% else %}
      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif%}           
      {% if section.settings.link_1 != blank %}  </a>
      {% endif%}
      <div class="featured-content">       
        {% if section.settings.title_1 != blank %}
        <h6 style="color:{{ section.settings.title_1_color }}">{{ section.settings.title_1 }}</h6>
        {% endif %}
        {% if section.settings.text_1 != blank %}
        <h2 style="color:{{ section.settings.text_1_color }}">{{ section.settings.text_1}}</h2>    
        {% endif %}  
        {% if section.settings.button_1 != blank %}
        <a class="btn three" href="{{ section.settings.link_1 }}" style="color:{{ section.settings.button_1_txt_color }};border:none;background-color:{{ section.settings.button_1_bg_color }};">{{ section.settings.button_1}}</a>    
        {% endif %}         
      </div>   
    </div> 
     <div class="grid__item wide--one-half post-large--one-half large--one-half medium-down--one-third small--grid__item img-hover-effect img-hover-effect-4">
      {% if section.settings.link_2 != blank %}<a class="banner_half_img" href="{{ section.settings.link_2 }}">{% endif%}
      {% if section.settings.image_2 != blank %}
      <img src="{{ section.settings.image_2 | img_url: 'master' }}" alt="{{ section.settings.title_2 }}" />
      {% else %}

      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif%}           
      {% if section.settings.link_2 != blank %}  </a>

      {% endif%}
      <div class="featured-content">     
        {% if section.settings.offer != blank or section.settings.offer_text != blank  %}
        <div class="offer_text">{{ section.settings.offer }}<p><span>{{ section.settings.offer_text }}</span></p></div>
        {% endif %} 
        {% if section.settings.title_2 != blank %}
        <h6 style="color:{{ section.settings.title_2_color }}">{{ section.settings.title_2 }}</h6>
        {% endif %}
        {% if section.settings.text_2 != blank %}
        <h2 style="color:{{ section.settings.text_2_color }}">{{ section.settings.text_2}}</h2>    
        {% endif %}  
        
        {% if section.settings.button_2 != blank %}
        <a class="btn four" href="{{ section.settings.link_2 }}" style="color:{{ section.settings.button_2_txt_color }};border:none;background-color:{{ section.settings.button_2_bg_color }};">{{ section.settings.button_2}}</a>    
        {% endif %}         
       </div>
      </div>
     </div>
    <div class="dt-sc-hr-invisible-large"></div>
  </div>    
  </div>
<style>
  .featured-content .btn.one:hover { background:{{ section.settings.button_4_hover_bg_color }} !important;color:{{ section.settings.button_4_hover_txt_color }} !important;}
  .featured-content .btn.two:hover { background:{{ section.settings.button_3_hover_bg_color }} !important; color:{{ section.settings.button_3_hover_txt_color }} !important;}
  .featured-content .btn.three:hover { background:{{ section.settings.button_1_hover_bg_color }} !important;color:{{ section.settings.button_1_hover_txt_color }} !important; }
  .featured-content .btn.four:hover { background:{{ section.settings.button_2_hover_bg_color }} !important;color:{{ section.settings.button_2_hover_txt_color }} !important; }
  .grid-banner-type-4 .featured-content h2 span { color:{{ section.settings.hot_text }}; }
  .grid-banner-type-4 .featured-content .offer_text { color:{{ section.settings.offer_text_clr }}; }
  .grid-banner-type-4 .featured-content p span:before,.grid-banner-type-4 .featured-content p span:after { background:{{ section.settings.offer_text_clr }}; }
  .grid-banner-type-4 .img-hover-effect-1:before { background:{{ section.settings.overlay_bgcolor_2 | color_modify: 'alpha', 0.1 }}; }
  .grid-banner-type-4 .img-hover-effect-2:before { background:{{ section.settings.overlay_bgcolor_3 | color_modify: 'alpha', 0.1 }}; }
  .grid-banner-type-4 .img-hover-effect-3:before { background:{{ section.settings.overlay_bgcolor_4 | color_modify: 'alpha', 0.1 }}; }
  .grid-banner-type-4 .img-hover-effect-4:before { background:{{ section.settings.overlay_bgcolor_5 | color_modify: 'alpha', 0.1 }}; }
</style>
      

