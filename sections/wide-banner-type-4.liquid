<div data-section-id="{{ section.id }}" data-section-type="wide-banner-type-4" class="wide-banner-type-4">  
  <div class="grid-uniform">    
      {% if section.settings.image != blank %} 
    <div class="wide-banner-type-4-block parallax" style="background-image:url('{{ section.settings.image | img_url: 'master' }}');background-repeat:no-repeat;background-size:cover;">
      {% else %}
        <div class="wide-banner-type-4-block parallax">
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif%}  
      
      
      <div class="wide-banner-type-4-content">                       
        {% if section.settings.text != blank %}
        <p style="color:{{ section.settings.text_color }}">{{ section.settings.text }}</p>
        {% endif %}
        {% if section.settings.title != blank %}
        <h2 style="color:{{ section.settings.title_color }};border:2px solid {{ section.settings.title_color }};border-left:none;border-right:none;">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.button != blank %}
        <a  href="{{ section.settings.link }}" style="color:{{ section.settings.button_txt_color }};border:none;background-color:{{ section.settings.button_bg_color }};" class="btn">{{ section.settings.button }}</a>    
        {% endif %}         
      </div> 
         
         <style>
           .wide-banner-type-4-content a:hover { background:{{ section.settings.button_bg_hover_color }} !important;color:{{ section.settings.button_text_hover_color }} !important; }
         </style>
         
      </div> 
  </div>
</div>
<div class="dt-sc-hr-invisible-large"></div>
{% schema %}
{
"name": "Wide Banner",
"class": "index-section",
"settings": [
{
"type": "image_picker",
"id": "image",
"label": "Image",
"info": "Size: 1920x1280"
},
{
"type": "text",
"id": "title",
"label": "Heading"
},
{
"type": "color",
"id": "title_color",
"label":"Title color",
"default": "#000"
},
{
"type": "textarea",
"id": "text",
"label": "Description"
},
{
"type": "color",
"id": "text_color",
"label":"Text color",
"default": "#000"
},
{
"type": "text",
"id": "button",
"label": "Button text"
},
{
"type": "color",
"id": "button_bg_color",
"label":"Background bg color",
"default": "#000"
},
{
"type": "color",
"id": "button_bg_hover_color",
"label":"Background hover bg",
"default": "#000"
},
{
"type": "color",
"id": "button_txt_color",
"label":"Text color",
"default": "#fff"
},
{
"type": "color",
"id": "button_text_hover_color",
"label":"Background hover text",
"default": "#000"
},
{
"type": "url",
"id": "link",
"label": "Link URL"
}
],
"presets": [
{
"name": "Wide Banner",
"category": "Image",
"blocks": []
}
]
}
{% endschema %}


