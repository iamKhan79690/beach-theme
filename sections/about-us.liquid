
<div data-section-id="{{ section.id }}"  data-section-type="About section" class="about-us">

  {% if section.settings.show_3_section %}
  <div class="dt-sc-hr-invisible-large"></div>
  <div class="section-three" style="background:{{section.settings.section_3_bgcolor}};">
    <div class="grid__item">
      <div class="container">
        <div class="grid__item">           
          {% if  section.settings.imgblock_1_img != blank %}
          <div class="grid__item wide--two-thirds post-large--two-thirds large--two-thirds">       
            <img src="{{  section.settings.imgblock_1_img | img_url: "master" }}" alt="{{ section.settings.imgblock_1_imgheading }}" />                          
          </div>
          {% endif %} 
          <div class="grid__item wide--one-third post-large--one-third large--one-third">
            {% if  section.settings.imgblock_2_img != blank %}
            <img src="{{  section.settings.imgblock_2_img | img_url: "master" }}" alt="{{ section.settings.imgblock_2_imgheading }}" />
            {% endif %} 
            {% if  section.settings.imgblock_3_img != blank %}
            <img src="{{  section.settings.imgblock_3_img | img_url: "master" }}" alt="{{ section.settings.imgblock_3_imgheading }}" />
            {% endif %} 
          </div>
        </div>
        <div class="grid__item">
          <div class="imgblock-detail">
            {% if section.settings.imgblock_desc != blank %}
            <p style="color:{{section.settings.imgblock_desccolor}};">{{section.settings.imgblock_desc}}</p>
            {% endif %} 
            {% if section.settings.btn_2_text != blank %}
            <a href="{{section.settings.link_2 }}"  class="about-btn btn" style="color:{{section.settings.btn_2_color}};background:{{section.settings.btn_2_bg}};">{{section.settings.btn_2_text }}</a>
            {% endif %} 
          </div>
        </div>
      </div>
    </div> 
  </div>
  {% endif %}

  {% if section.settings.show_2_section != blank %}
  <div class="grid-uniform section-two">
    <div class="container">
      <div class="grid__item post-large--one-half">
        {% if section.settings.section_2_mainheading != blank %}
        <h2>{{section.settings.section_2_mainheading }}</h2>
        {% endif %}
        {% if section.settings.section_2_subheading != blank %}
        <h5>{{section.settings.section_2_subheading }}</h5>        
        <div class="invisible-small"></div>
        {% endif %}     
        {% if section.settings.section_2_introtxt != blank %}
        {{section.settings.section_2_introtxt }}
        <div class="invisible-small"></div>
        {% endif %} 
        <div class="grid__item">
          <div class="icon-block">
            {% if section.settings.section_2_icon_clsone != blank %}
            <div class="icon-one">
              <span class="{{section.settings.section_2_icon_clsone }}"></span>
            </div>
            {% endif %} 
            {% if section.settings.section_2_icon_titleone != blank %}
            <h4>{{section.settings.section_2_icon_titleone }}</h4>
            {% endif %} 
            {% if section.settings.section_2_icon_detailone != blank %}
            {{section.settings.section_2_icon_detailone }}
            {% endif %} 
          </div>      
          <div class="icon-block">
            {% if section.settings.section_2_icon_clstwo != blank %}
            <div class="icon-one">   
              <span class="{{section.settings.section_2_icon_clstwo }}"></span>   
            </div>
            {% endif %}
            {% if section.settings.section_2_icon_titletwo != blank %}
            <h4>{{section.settings.section_2_icon_titletwo }}</h4>
            {% endif %} 
            {% if section.settings.section_2_icon_detailtwo != blank %}
            {{section.settings.section_2_icon_detailtwo }}
            {% endif %} 
          </div>
          <div class="icon-block">
            {% if section.settings.section_2_icon_clsthree != blank %}
            <div class="icon-one">
              <span class="{{section.settings.section_2_icon_clsthree }}"></span> 
            </div>
            {% endif %}            
            {% if section.settings.section_2_icon_titlethree != blank %}
            <h4>{{section.settings.section_2_icon_titlethree }}</h4>
            {% endif %} 
            {% if section.settings.section_2_icon_detailthree != blank %}
            {{section.settings.section_2_icon_detailthree }}
            {% endif %} 
          </div>
        </div>
      </div>      
      {% if section.settings.right_image != blank %}
      <div class="grid__item post-large--one-half">
        <img src="{{ section.settings.right_image | img_url: '1024x1024' }}" alt="" title="" /> 
      </div>
      {% endif %}
    </div>
  </div>
  {% endif %}


  {% if section.settings.show_4_section %}
  <div class="section-four">
    <div class="container">
      {% if section.settings.imgsection_1_section %}
      <div class="grid__item inner-row" >        
        {% if  section.settings.imgsection_1_img != blank %}
        <div class="grid__item wide--one-half post-large--one-half large--one-half">
          <div class="img-section">    
            <img src="{{  section.settings.imgsection_1_img | img_url: "master" }}" alt="{{ section.settings.imgsection_1_img }}" />   
          </div>
        </div>
        {% endif %}
        <div class="grid__item wide--one-half post-large--one-half large--one-half">
          <div class="img-section-desc right-section">
            {% if section.settings.imgsection_1_desc != blank %}
            <p>{{section.settings.imgsection_1_desc}}</p>  
            {% endif %}
            {% if section.settings.author_1_name != blank %}
            <span>{{section.settings.author_1_name}}</span>
            {% endif %}
          </div>
        </div>
      </div>
      {% endif %}
      {% if section.settings.imgsection_2_section %}
      <div class="grid__item inner-row" >
        <div class="grid__item wide--one-half post-large--one-half large--one-half">
          <div class="img-section-desc left-section">
            {% if section.settings.imgsection_2_desc != blank %}
            <p>{{section.settings.imgsection_2_desc}}</p>  
            {% endif %}
            {% if section.settings.author_2_name != blank %}
            <span>{{section.settings.author_2_name}}</span>
            {% endif %}
          </div>
        </div>        
        {% if  section.settings.imgsection_2_img != blank %}
        <div class="grid__item wide--one-half post-large--one-half large--one-half">
          <div class="img-section">          
            <img src="{{  section.settings.imgsection_2_img | img_url: "master" }}" alt="{{ section.settings.imgsection_2_img }}" />        
          </div>
        </div>
        {% endif %}
      </div>
      {% endif %}
    </div>
  </div>
  {% endif %}

  {% if section.settings.test_section %}
  <div class="testimonial-section">
    <div class="container">
      <div class="grid__item ">
        {% if section.settings.test_title %}
        <h2 style="color:{{section.settings.testtitle_color}}">{{section.settings.test_title}}</h2>
        <div class="invisible-small"></div>
        {% endif %}
        <div class="grid__item testimonial-block">
          <div id="testimonial-car" class="owl-carousel">
            {% if section.settings.testmonial_1_section %}
            <div class="item">
              {% if section.settings.test_1_desc %}
              <div class="blockquote">
                <blockquote>
                  "{{section.settings.test_1_desc}}"
                </blockquote>
              </div>
              {% endif %}
              <div class="testimonial-author">
                {% if  section.settings.test_1_img  != blank %}
                <div class="author-img">   <img src="{{  section.settings.test_1_img  | img_url: "master" }}" alt="{{ section.settings.team_1_imgheading }}" /></div>
                {% endif %}
                <span>
                  {% if section.settings.test_1_author %}
                  <h4> {{section.settings.test_1_author}}</h4>
                  {% endif %}
                  {% if section.settings.test_1_designation %}
                  <h6>{{section.settings.test_1_designation}}</h6>
                  {% endif %}
                </span>
              </div>
            </div>
            {% endif %} 
            {% if section.settings.testmonial_2_section %}
            <div class="item">
              {% if section.settings.test_2_desc %}
              <div class="blockquote">
                <blockquote>
                  "{{section.settings.test_2_desc}}"
                </blockquote>
              </div>
              {% endif %}
              <div class="testimonial-author">
                {% if  section.settings.test_2_img  != blank %}
                <div class="author-img">   <img src="{{  section.settings.test_2_img  | img_url: "master" }}" alt="{{ section.settings.team_2_imgheading }}" /></div>
                {% endif %}                
                {% if section.settings.test_2_author %}
                <span>                  
                  <h4> {{section.settings.test_2_author}}</h4>                
                  {% if section.settings.test_2_designation %}
                  <h6>{{section.settings.test_2_designation}}</h6>
                  {% endif %}
                </span>
                {% endif %}           
              </div>
            </div>
            {% endif %} 
            {% if section.settings.testmonial_3_section %}
            <div class="item">
              {% if section.settings.test_3_desc %}
              <div class="blockquote">
                <blockquote>
                  "{{section.settings.test_3_desc}}"
                </blockquote>
              </div>
              {% endif %}
              <div class="testimonial-author">
                {% if  section.settings.test_3_img  != blank %}
                <div class="author-img">   <img src="{{  section.settings.test_3_img  | img_url: "master" }}" alt="{{ section.settings.team_3_imgheading }}" /></div>
                {% endif %}
                <span>
                  {% if section.settings.test_3_author %}
                  <h4> {{section.settings.test_3_author}}</h4>
                  {% endif %}
                  {% if section.settings.test_3_designation %}
                  <h6>{{section.settings.test_3_designation}}</h6>
                  {% endif %}
                </span>
              </div>
            </div>
            {% endif %} 
          </div>
        </div>
      </div>
    </div>
  </div>
  {% endif %} 


  {% if section.settings.client_section %}
  <div class="grid-uniform section-seven">
    <div class="container"> 
      {% if  section.settings.section_7_title  != blank %}
      <div class="main-title">      
        <h2 style="color:{{section.settings.section_7_title_color  }}">{{section.settings.section_7_title}}</h2>      
        {% if  section.settings. section_7_subtitle  != blank %}
        <h4 style="color:{{section.settings.section_7_subtitle_color}}">{{section.settings.section_7_subtitle}}</h4>
        {% endif %}
        {% if  section.settings.section_7_img  != blank %}
        <img src="{{  section.settings.section_7_img  | img_url: "master" }}" alt="{{ section.settings.section_7_imgheading }}" />
        {% endif %}
      </div>
      <div class="invisible-small"></div>
      {% endif %}
      <div class="grid__item">
        <div id="client-car" class="owl-carousel client-section">
          {% if section.blocks.size > 0 %}  
          {% for block in section.blocks %}
          <div class="item">
            {% if  block.settings.client_1_img != blank %}
            <a href="{{block.settings.client_link}}">    <img src="{{ block.settings.client_1_img | img_url: "master" }}" alt="{{ block.settings.client_1_imgheading }}" /></a>
            {% endif %}
          </div>
          {% endfor %}
          {% endif %}
          {% if settings.aboutvedafourclient_1_img %}
          <div class="item">
            <a href="#"> <img src="{{ 'aboutvedafourclient_1_img.jpg' | asset_url }}" alt="" /></a>
          </div>
          {% endif %} 
        </div>
      </div>
    </div>
  </div>
  {% endif %} 
</div>

<style type="text/css">

  .about-us  .section-three img{border: 10px solid {{section.settings.img_bordercolor}};}

  .about-us .section-two { background:{{section.settings.aboutvedafive_2_sectionbg}};}

  .about-us .section-two h2{color:{{section.settings.aboutvedafive_2_txtcolor}};}

  .about-us .section-two h3 {  color:{{section.settings.aboutvedafive_2_txtcolor}};}

  .about-us .section-two  h5 ,  .about-us .section-two p{color:{{section.settings.aboutvedafive_2_txtcolor}};}

  .about-us .icon-block  h4{color:{{section.settings.aboutvedafive_2_txtcolor}};}

  .about-us .icon-block::after { border: 1px solid {{section.settings.aboutvedafive_2_iconcolor}};}

  .about-us .icon-one::before{ box-shadow:5px 0 0 0 {{section.settings.aboutvedafive_2_iconcolor}};}

  .about-us .section-two span {color:{{section.settings.aboutvedafive_2_iconcolor}};}

  .about-us .icon-block  h4{color:{{section.settings.aboutvedafive_2_txtcolor}};}

  .about-us .icon-one::before{background: {{section.settings.aboutvedafive_2_txtcolor}};}

  .about-us .img-section-desc{background:{{section.settings.imgsection_1_bg}}; }

  .about-us .img-section-desc.right-section{box-shadow: 20px 20px 20px 0 {{section.settings.imgsection_1_box}};}

  .about-us .img-section-desc.left-section{box-shadow: -20px 20px 20px 0 {{section.settings.imgsection_1_box}};}

  .about-us .section-four .img-section-desc p{color:{{section.settings.imgsection_desccolor }};}

  .about-us .section-four .img-section-desc span{color:{{section.settings.imgsectionauthorcolor }};}

  .about-us blockquote {border: 1px solid {{section.settings.test_bordercolor}};}

  .about-us blockquote::after {background:transparent none repeat scroll 0 0;border-bottom: 1px solid {{section.settings.test_bordercolor}};border-right: 1px solid {{section.settings.test_bordercolor}};}

  .about-us .author-img { border: 1px solid {{section.settings.test_bordercolor}};}

  .about-us .testimonial-author h4{color:{{section.settings.test_color}};}

  .about-us .testimonial-author h6{color:{{section.settings.test_bordercolor}};font-weight:bold;}

  .about-us  .owl-buttons .owl-prev:hover , .vedabout-four  .owl-buttons .owl-next:hover{border:1px solid {{section.settings.teamhoverbg}};background:{{section.settings.teamhoverbg}};;color:{{section.settings.teamhovercolor}};}

  .about-us  .testimonial-section {background:{{section.settings.test_bgcolor}};}

  .about-us blockquote::before {border-top: 14px solid {{section.settings.test_bgcolor}};}

</style>


